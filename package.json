{
  "name": "editkit",
  "version": "0.1.1",
  "description": "Robust LLM edit-format toolkit for TypeScript. Parse and apply SEARCH/REPLACE blocks, unified diffs, and whole-file edits — battle-tested fuzzy matching ported from aider.",
  "keywords": [
    "llm",
    "ai",
    "ai-sdk",
    "vercel-ai-sdk",
    "anthropic",
    "openai",
    "claude",
    "coding-agent",
    "code-edit",
    "codemod",
    "codegen",
    "search-replace",
    "unified-diff",
    "whole-file",
    "diff",
    "patch",
    "edit",
    "apply",
    "aider",
    "cursor",
    "cline",
    "continue",
    "mastra",
    "fuzzy-match",
    "streaming",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "license": "MIT",
  "author": "Arielton Oberek <contact@arielton.com>",
  "homepage": "https://github.com/arioberek/editkit-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arioberek/editkit-ts.git"
  },
  "bugs": {
    "url": "https://github.com/arioberek/editkit-ts/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
