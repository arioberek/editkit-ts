{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" }
  },
  "files": {
    "ignore": [
      "**/dist",
      "**/node_modules",
      "**/.turbo",
      "**/.next",
      "**/.source",
      "**/.vercel",
      "**/next-env.d.ts",
      "examples/mini-coding-agent/target",
      "examples/mini-coding-agent/fixtures",
      "apps/docs/content"
    ]
  }
}
